<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Free Fire Tournament | APT Studios</title>
    <!-- Google Fonts & Font Awesome Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;900&family=Rajdhani:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* --- CSS VARIABLES & RESET --- */
        :root {
            --primary: #ff4655;
            --secondary: #00f0ff;
            --accent: #ffb703;
            --bg-dark: #0a0b10;
            --glass-bg: rgba(18, 22, 36, 0.65);
            --glass-border: rgba(255, 255, 255, 0.12);
            --glass-glow: rgba(0, 240, 255, 0.15);
            --text-light: #f0f4f8;
            --text-muted: #a0aec0;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Rajdhani', sans-serif;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-light);
            overflow-x: hidden;
            background-image: 
                radial-gradient(circle at 15% 20%, rgba(255, 70, 85, 0.15) 0%, transparent 40%),
                radial-gradient(circle at 85% 80%, rgba(0, 240, 255, 0.15) 0%, transparent 40%);
            min-height: 100vh;
        }

        /* --- BACKGROUND ANIMATED ELEMENTS --- */
        .grid-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: linear-gradient(to right, rgba(255,255,255,0.02) 1px, transparent 1px),
                              linear-gradient(to bottom, rgba(255,255,255,0.02) 1px, transparent 1px);
            background-size: 40px 40px;
            z-index: -1;
        }

        /* --- GLASS CONTAINER STYLES --- */
        .glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .glass-card:hover {
            border-color: rgba(0, 240, 255, 0.4);
            box-shadow: 0 0 25px var(--glass-glow);
            transform: translateY(-5px);
        }

        /* --- LAYOUT & WRAPPER --- */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem 1.5rem;
        }

        /* --- HEADER / HERO SECTION --- */
        header {
            text-align: center;
            padding: 3rem 1rem 2rem;
            position: relative;
        }

        .badge-live {
            display: inline-block;
            background: rgba(255, 70, 85, 0.2);
            border: 1px solid var(--primary);
            color: var(--primary);
            padding: 6px 16px;
            border-radius: 50px;
            font-family: 'Orbitron', sans-serif;
            font-size: 0.85rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 1rem;
            animation: pulse 2s infinite;
        }

        h1 {
            font-family: 'Orbitron', sans-serif;
            font-size: clamp(2.5rem, 6vw, 4.5rem);
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 3px;
            background: linear-gradient(135deg, #fff 30%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 30px rgba(0, 240, 255, 0.3);
            margin-bottom: 0.5rem;
        }

        .subtitle {
            font-size: 1.2rem;
            color: var(--text-muted);
            letter-spacing: 1px;
        }

        /* --- DETAILS GRID --- */
        .grid-layout {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            margin: 2.5rem 0;
        }

        .info-card {
            padding: 1.8rem;
            display: flex;
            align-items: flex-start;
            gap: 1.2rem;
        }

        .info-card i {
            font-size: 2rem;
            color: var(--secondary);
            background: rgba(0, 240, 255, 0.1);
            padding: 12px;
            border-radius: 12px;
            border: 1px solid rgba(0, 240, 255, 0.2);
        }

        .info-content h3 {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.1rem;
            color: var(--text-muted);
            margin-bottom: 0.3rem;
            text-transform: uppercase;
        }

        .info-content p {
            font-size: 1.3rem;
            font-weight: 700;
            color: #fff;
        }

        /* --- TEAMS VS SECTION --- */
        .vs-section {
            padding: 2.5rem;
            margin: 2rem 0;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .vs-section::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,70,85,0.05) 0%, transparent 60%);
            pointer-events: none;
        }

        .teams-container {
            display: flex;
            justify-content: space-around;
            align-items: center;
            flex-wrap: wrap;
            gap: 2rem;
            margin-top: 1.5rem;
        }

        .team-box {
            flex: 1;
            min-width: 200px;
            padding: 1.5rem;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: 0.3s ease;
        }

        .team-alpha { border-bottom: 3px solid var(--primary); }
        .team-bravo { border-bottom: 3px solid var(--secondary); }

        .team-box:hover {
            background: rgba(255, 255, 255, 0.07);
            transform: scale(1.03);
        }

        .team-box h2 {
            font-family: 'Orbitron', sans-serif;
            font-size: 2rem;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .vs-badge {
            font-family: 'Orbitron', sans-serif;
            font-size: 2.5rem;
            font-weight: 900;
            font-style: italic;
            color: var(--accent);
            text-shadow: 0 0 15px rgba(255, 183, 3, 0.5);
        }

        /* --- HIGHLIGHT / FEE & PRIZE BANNER --- */
        .highlight-banner {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            margin: 2rem 0;
        }

        .banner-card {
            padding: 2rem;
            text-align: center;
            position: relative;
        }

        .fee-card { border-left: 4px solid #00ff88; }
        .award-card { border-left: 4px solid var(--accent); }

        .banner-card h3 {
            font-family: 'Orbitron', sans-serif;
            font-size: 1rem;
            color: var(--text-muted);
            margin-bottom: 0.5rem;
            text-transform: uppercase;
        }

        .price-tag {
            font-size: 2.5rem;
            font-weight: 900;
            font-family: 'Orbitron', sans-serif;
            color: #00ff88;
            text-shadow: 0 0 15px rgba(0, 255, 136, 0.4);
        }

        .strike-through {
            text-decoration: line-through;
            color: var(--text-muted);
            font-size: 1.2rem;
            margin-right: 10px;
        }

        /* --- BUTTONS & ACTIONS --- */
        .action-area {
            text-align: center;
            margin: 3rem 0;
        }

        .deadline-text {
            color: var(--primary);
            font-weight: 700;
            font-size: 1.1rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-group {
            display: flex;
            justify-content: center;
            gap: 1.5rem;
            flex-wrap: wrap;
        }

        /* Cyberpunk Hover Button Animation */
        .btn {
            position: relative;
            padding: 1rem 2.5rem;
            font-family: 'Orbitron', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #fff;
            text-decoration: none;
            border: none;
            background: transparent;
            cursor: pointer;
            overflow: hidden;
            border-radius: 8px;
            transition: all 0.3s ease;
            z-index: 1;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), #d62828);
            box-shadow: 0 0 20px rgba(255, 70, 85, 0.4);
        }

        .btn-discord {
            background: linear-gradient(135deg, #5865F2, #404EED);
            box-shadow: 0 0 20px rgba(88, 101, 242, 0.4);
        }

        .btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.6s ease;
        }

        .btn:hover::before {
            left: 100%;
        }

        .btn:hover {
            transform: translateY(-3px) scale(1.03);
            box-shadow: 0 0 30px rgba(255, 255, 255, 0.4);
        }

        /* --- FOOTER --- */
        footer {
            margin-top: 4rem;
            padding: 2rem 0;
            border-top: 1px solid var(--glass-border);
            text-align: center;
            color: var(--text-muted);
        }

        .contact-links {
            display: flex;
            justify-content: center;
            gap: 2rem;
            margin-top: 1rem;
            flex-wrap: wrap;
        }

        .contact-links a {
            color: var(--secondary);
            text-decoration: none;
            transition: color 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .contact-links a:hover {
            color: #fff;
            text-shadow: 0 0 10px var(--secondary);
        }

        /* --- KEYFRAMES --- */
        @keyframes pulse {
            0% { opacity: 0.6; }
            50% { opacity: 1; filter: drop-shadow(0 0 8px var(--primary)); }
            100% { opacity: 0.6; }
        }

        /* Responsive Adjustments */
        @media (max-width: 768px) {
            .teams-container { flex-direction: column; }
            .vs-badge { margin: 1rem 0; }
            .btn { width: 100%; }
        }
    </style>
</head>
<body>

    <div class="grid-bg"></div>

    <div class="container">
        <!-- HERO SECTION -->
        <header>
            <div class="badge-live"><i class="fa-solid fa-crosshairs"></i> Registration Open</div>
            <h1>Free Fire Showdown</h1>
            <p class="subtitle">Organized by AAM OS</p>
        </header>

        <!-- MAIN MATCH DETAILS GRID -->
        <div class="grid-layout">
            <div class="glass-card info-card">
                <i class="fa-solid fa-calendar-days"></i>
                <div class="info-content">
                    <h3>Match Date</h3>
                    <p>8th August 2026</p>
                </div>
            </div>

            <div class="glass-card info-card">
                <i class="fa-solid fa-clock"></i>
                <div class="info-content">
                    <h3>Time Slot</h3>
                    <p>11:30 AM - 4:30 PM</p>
                </div>
            </div>

            <div class="glass-card info-card">
                <i class="fa-solid fa-globe"></i>
                <div class="info-content">
                    <h3>Mode</h3>
                    <p>Online Tournament</p>
                </div>
            </div>

            <div class="glass-card info-card">
                <i class="fa-solid fa-sitemap"></i>
                <div class="info-content">
                    <h3>Match Format</h3>
                    <p>Based on Player Count</p>
                </div>
            </div>
        </div>

        <!-- TEAMS SHOWCASE -->
        <section class="glass-card vs-section">
            <h3 style="font-family: 'Orbitron'; color: var(--text-muted); text-transform: uppercase; margin-bottom: 1rem;">Clash of Factions</h3>
            <div class="teams-container">
                <div class="team-box team-alpha">
                    <i class="fa-solid fa-fire-flame-curved" style="font-size: 2.5rem; color: var(--primary); margin-bottom: 0.5rem;"></i>
                    <h2>Team Alpha</h2>
                </div>
                <div class="vs-badge">VS</div>
                <div class="team-box team-bravo">
                    <i class="fa-solid fa-bolt" style="font-size: 2.5rem; color: var(--secondary); margin-bottom: 0.5rem;"></i>
                    <h2>Team Bravo</h2>
                </div>
            </div>
        </section>

        <!-- FEES & AWARDS BANNER -->
        <div class="highlight-banner">
            <div class="glass-card banner-card fee-card">
                <h3>Entry Fee</h3>
                <div class="price-tag">
                    <span class="strike-through">Very High</span> ₹0
                </div>
                <p style="color: var(--text-muted); margin-top: 5px;">100% Free Entry</p>
            </div>

            <div class="glass-card banner-card award-card">
                <h3>Rewards & Recognition</h3>
                <div style="font-size: 1.8rem; font-weight: 700; color: var(--accent); font-family: 'Orbitron', sans-serif; margin: 10px 0;">
                    <i class="fa-solid fa-award"></i> Participation Certificate
                </div>
                <p style="color: var(--text-muted);">Official completion certificate for players</p>
            </div>
        </div>

        <!-- CALL TO ACTION & DEADLINE -->
        <div class="glass-card action-area" style="padding: 2.5rem;">
            <div class="deadline-text">
                <i class="fa-solid fa-triangle-exclamation"></i>
                Last Date to Register: 7th August 2026 at 12:30 PM
            </div>
            
            <div class="btn-group">
                <a href="https://discord.gg/EmW7q2SkDP" target="_blank" class="btn btn-discord">
                    <i class="fa-brands fa-discord"></i> Join Discord to Register
                </a>
                <a href="mailto:aptstudiosss@gmail.com" class="btn btn-primary">
                    <i class="fa-solid fa-envelope"></i> Contact Host
                </a>
            </div>
        </div>

        <!-- FOOTER -->
        <footer>
            <p>&copy; 2026 APT Studios (AAM OS). All rights reserved.</p>
            <div class="contact-links">
                <a href="mailto:aptstudiosss@gmail.com"><i class="fa-solid fa-envelope"></i> aptstudiosss@gmail.com</a>
                <a href="https://discord.gg/EmW7q2SkDP" target="_blank"><i class="fa-brands fa-discord"></i> Join Discord</a>
            </div>
        </footer>
    </div>

</body>
</html>
